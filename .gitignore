skill_output/*
# 補足: Git は空のディレクトリを追跡しないため、リポジトリに skill_output を残す場合は .gitkeep を追跡する
!skill_output/.gitkeep
skill_out/*
!skill_out/.gitkeep
tests/skill_out_smoke/
.env_local
*.excalidraw
.agent/skills/*/*/*.png
.cursor/skills/*/*/*.png

# Test artifacts (vcd skill)
**/tests/temp_test.csv
**/tests/test_out_logic/
**/vcd-categorical-analysis/templates/skill_out/
